name = "moonbit-community/XMLParser"

version = "0.2.5"

import {
  "moonbitlang/quickcheck@0.14.0",
  "moonbitlang/x@0.4.38",
}

readme = "README.md"

repository = "https://github.com/moonbit-community/XMLParser"

license = "Apache-2.0"

keywords = [ "XML", "parser" ]

description = "An XML parsing library written in MoonBit that converts XML strings into structured data, supporting elements, attributes, comments, CDATA, and processing instructions."

options(
  source: "src",
)
